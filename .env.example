X402_AGENT_ADDRESS=4IVP3CZFNPI7BWGWS5NSF2SWGZSBEFWFRVLAEEHFWV5X24E6DX76ETBWTY
# X402_AGENT_MNEMONIC=<your mnemonic here — never commit a real funded mnemonic>
