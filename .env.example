# USDC asset on Algorand testnet
USDC_TESTNET_ASSET_ID=10458941

# Set to true for demo mode (no real payment needed)
# Set to false to require real x402 payments
BYPASS_X402=true

# x402 server agent wallet — auto-pays on-chain (0.05 ALGO per call)
